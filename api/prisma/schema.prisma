// PulseQueue database schema
// Design notes:
// - Every row that belongs to a tenant carries tenant_id -> enforced at query layer for isolation.
// - runs/steps use string enums (not native Postgres enums) so new statuses can be added without a migration.
// - Indexes are placed on every foreign key we query by in the dashboard (runs.workflowId, steps.runId, steps.status).

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

enum StepStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
  DEAD_LETTER
}

enum StepType {
  HTTP
  SCRIPT
  AI_ENRICHMENT
  WEBHOOK
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  workflows Workflow[]
  apiKeys   ApiKey[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(MEMBER)
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  workflows    Workflow[] @relation("CreatedByUser")

  @@index([tenantId])
  @@map("users")
}

model Workflow {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  dagJson   Json     @map("dag_json")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  creator   User     @relation("CreatedByUser", fields: [createdBy], references: [id])
  runs      Run[]

  @@index([tenantId])
  @@map("workflows")
}

model Run {
  id          String    @id @default(uuid())
  workflowId  String    @map("workflow_id")
  status      RunStatus @default(PENDING)
  triggeredBy String    @map("triggered_by")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workflow    Workflow  @relation(fields: [workflowId], references: [id])
  steps       Step[]

  @@index([workflowId])
  @@index([status])
  @@map("runs")
}

model Step {
  id           String     @id @default(uuid())
  runId        String     @map("run_id")
  stepKey      String     @map("step_key")
  type         StepType
  status       StepStatus @default(PENDING)
  attemptCount Int        @default(0) @map("attempt_count")
  input        Json?
  output       Json?
  error        String?
  nextAttemptAt DateTime? @map("next_attempt_at")
  idempotencyKey String   @unique @map("idempotency_key")
  startedAt    DateTime?  @map("started_at")
  finishedAt   DateTime?  @map("finished_at")

  run          Run        @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([status])
  @@map("steps")
}

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  keyHash   String   @unique @map("key_hash")
  rateLimit Int      @default(100) @map("rate_limit")
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}
